#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ./scripts/package-skill <skill-name-or-path> [output-dir]

Create a zip package for an OpenClaw/Codex skill folder.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage
  exit 1
fi

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INPUT="$1"
OUTPUT_DIR="${2:-$ROOT_DIR/dist}"

if [[ -d "$INPUT" ]]; then
  SKILL_DIR="$INPUT"
else
  SKILL_DIR="$ROOT_DIR/skills/$INPUT"
fi

if [[ ! -d "$SKILL_DIR" ]]; then
  echo "Skill directory not found: $SKILL_DIR" >&2
  exit 1
fi

if [[ ! -f "$SKILL_DIR/SKILL.md" ]]; then
  echo "SKILL.md not found in: $SKILL_DIR" >&2
  exit 1
fi

SKILL_NAME="$(basename "$SKILL_DIR")"
VERSION="0.1.0"

if [[ -f "$SKILL_DIR/_meta.json" ]]; then
  VERSION="$(
    python3 - "$SKILL_DIR/_meta.json" <<'PY'
import json
import sys
from pathlib import Path

meta_path = Path(sys.argv[1])
data = json.loads(meta_path.read_text(encoding="utf-8"))
print(data.get("version", "0.1.0"))
PY
  )"
fi

mkdir -p "$OUTPUT_DIR"
OUTPUT_PATH="$OUTPUT_DIR/${SKILL_NAME}-${VERSION}.zip"

PARENT_DIR="$(cd "$SKILL_DIR/.." && pwd)"
rm -f "$OUTPUT_PATH"

(
  cd "$PARENT_DIR"
  zip -rq "$OUTPUT_PATH" "$SKILL_NAME" -x '*.DS_Store'
)

echo "$OUTPUT_PATH"
