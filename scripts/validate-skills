#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VALIDATE_SCRIPT="$ROOT_DIR/scripts/quick-validate-skill.py"
SKILLS_DIR="$ROOT_DIR/skills"

if [[ ! -f "$VALIDATE_SCRIPT" ]]; then
  echo "Validation script not found: $VALIDATE_SCRIPT" >&2
  exit 1
fi

if [[ ! -d "$SKILLS_DIR" ]]; then
  echo "skills directory not found: $SKILLS_DIR" >&2
  exit 1
fi

status=0
found=0

while IFS= read -r skill_dir; do
  if [[ -f "$skill_dir/SKILL.md" ]]; then
    found=1
    rel_path="${skill_dir#$ROOT_DIR/}"
    echo "Validating $rel_path"
    if ! python3 "$VALIDATE_SCRIPT" "$skill_dir"; then
      status=1
    fi
  fi
done < <(find "$SKILLS_DIR" -mindepth 1 -maxdepth 1 -type d | sort)

if [[ "$found" -eq 0 ]]; then
  echo "No skills with SKILL.md found under $SKILLS_DIR" >&2
  exit 1
fi

if [[ "$status" -eq 0 ]]; then
  echo "All skills are valid."
else
  echo "One or more skills failed validation." >&2
fi

exit "$status"
